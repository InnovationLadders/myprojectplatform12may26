/**
 * Calculate achievements based on total points
 */
export const calculateAchievements = (totalPoints: number, config: AchievementConfig) => {
  const achievements = {
    trophy: 0,
    platinum: 0,
    gold: 0,
    silver: 0,
    bronze: 0,
  };

  let remaining = totalPoints;

  achievements.trophy = Math.floor(remaining / config.trophy);
  remaining = remaining % config.trophy;

  achievements.platinum = Math.floor(remaining / config.platinum);
  remaining = remaining % config.platinum;

  achievements.gold = Math.floor(remaining / config.gold);
  remaining = remaining % config.gold;

  achievements.silver = Math.floor(remaining / config.silver);
  remaining = remaining % config.silver;

  achievements.bronze = Math.floor(remaining / config.bronze);

  return achievements;
};

/**
 * Check and award new achievements
 * Internal helper function
 */
const checkAndAwardAchievements = async (studentId: string): Promise<void> => {
  try {
    const points = await getStudentPoints(studentId);
    const config = await getAchievementConfig();
    const achievements = calculateAchievements(points.totalPoints, config);

    // Get existing achievements
    const { data: existingAchievements, error } = await supabase
      .from('student_achievements')
      .select('*')
      .eq('student_id', studentId);

    if (error) {
      console.error('Error fetching existing achievements:', error);
      return;
    }

    const existingCounts: Record<string, number> = {
      trophy: 0,
      platinum: 0,
      gold: 0,
      silver: 0,
      bronze: 0,
    };

    existingAchievements?.forEach((achievement) => {
      existingCounts[achievement.achievement_type]++;
    });

    // Award new achievements
    const newAchievements: any[] = [];

    for (const [type, count] of Object.entries(achievements)) {
      const existingCount = existingCounts[type];
      const newAchievementsCount = count - existingCount;

      for (let i = 0; i < newAchievementsCount; i++) {
        newAchievements.push({
          student_id: studentId,
          achievement_type: type,
          level: existingCount + i + 1,
          points_at_unlock: points.totalPoints,
        });
      }
    }

    if (newAchievements.length > 0) {
      const { error: insertError } = await supabase
        .from('student_achievements')
        .insert(newAchievements);

      if (insertError) {
        console.error('Error inserting new achievements:', insertError);
      }
    }
  } catch (error) {
    console.error('Error checking and awarding achievements:', error);
  }
};

/**
 * Get student achievements
 */
export const getStudentAchievements = async (studentId: string): Promise<StudentAchievement[]> => {
  try {
    const { data, error } = await supabase
      .from('student_achievements')
      .select('*')
      .eq('student_id', studentId)
      .order('earned_at', { ascending: false });

    if (error) {
      console.error('Error fetching student achievements:', error);
      return [];
    }

    return (data || []).map((achievement) => ({
      id: achievement.id,
      studentId: achievement.student_id,
      achievementType: achievement.achievement_type as 'bronze' | 'silver' | 'gold' | 'platinum' | 'trophy',
      level: achievement.level,
      earnedAt: achievement.earned_at,
      pointsAtUnlock: achievement.points_at_unlock,
    }));
  } catch (error) {
    console.error('Error in getStudentAchievements:', error);
    return [];
  }
};

/**
 * Get points history for a student
 */
export const getPointsHistory = async (
  studentId: string,
  limitCount: number = 20
): Promise<PointsHistory[]> => {
  try {
    const { data, error } = await supabase
      .from('points_history')
      .select('*')
      .eq('student_id', studentId)
      .order('timestamp', { ascending: false })
      .limit(limitCount);

    if (error) {
      console.error('Error fetching points history:', error);
      return [];
    }

    return (data || []).map((history) => ({
      id: history.id,
      studentId: history.student_id,
      activityType: history.activity_type as PointsHistory['activityType'],
      pointsEarned: history.points_earned,
      projectId: history.project_id,
      description: history.description,
      timestamp: history.timestamp,
      metadata: history.metadata,
    }));
  } catch (error) {
    console.error('Error in getPointsHistory:', error);
    return [];
  }
};

/**
 * Get top students by points
 */
export const getTopStudents = async (schoolId?: string, limitCount: number = 10): Promise<StudentPoints[]> => {
  try {
    let query = supabase
      .from('student_points')
      .select('*')
      .order('total_points', { ascending: false })
      .limit(limitCount);

    const { data, error } = await query;

    if (error) {
      console.error('Error fetching top students:', error);
      return [];
    }

    return (data || []).map((student) => ({
      userId: student.user_id,
      totalPoints: student.total_points,
      initiationPoints: student.initiation_points,
      progressPoints: student.progress_points,
      chatPoints: student.chat_points,
      filePoints: student.file_points,
      weightedScorePoints: student.weighted_score_points,
      lastUpdated: student.last_updated,
    }));
  } catch (error) {
    console.error('Error in getTopStudents:', error);
    return [];
  }
};

/**
 * Manually adjust points (admin function)
 */
export const manuallyAdjustPoints = async (
  studentId: string,
  pointsToAdd: number,
  reason: string,
  adminId: string
): Promise<void> => {
  try {
    const currentPoints = await getStudentPoints(studentId);
    const newTotal = Math.max(0, currentPoints.totalPoints + pointsToAdd);

    const { error } = await supabase
      .from('student_points')
      .update({
        total_points: newTotal,
        last_updated: new Date().toISOString(),
      })
      .eq('user_id', studentId);

    if (error) {
      console.error('Error manually adjusting points:', error);
      throw error;
    }

    await addPointsHistory({
      studentId,
      activityType: 'manual_adjustment',
      pointsEarned: pointsToAdd,
      description: `Manual adjustment by admin: ${reason}`,
      metadata: { adminId, reason, manualAdjustment: true },
    });

    await checkAndAwardAchievements(studentId);
  } catch (error) {
    console.error('Error in manuallyAdjustPoints:', error);
    throw error;
  }
};

/**
 * Reset student points (admin function)
 */
export const resetStudentPoints = async (studentId: string): Promise<void> => {
  try {
    // Reset points
    const { error: pointsError } = await supabase
      .from('student_points')
      .update({
        total_points: 0,
        initiation_points: 0,
        progress_points: 0,
        chat_points: 0,
        file_points: 0,
        weighted_score_points: 0,
        last_updated: new Date().toISOString(),
      })
      .eq('user_id', studentId);

    if (pointsError) {
      console.error('Error resetting student points:', pointsError);
      throw pointsError;
    }

    // Delete achievements
    const { error: achievementsError } = await supabase
      .from('student_achievements')
      .delete()
      .eq('student_id', studentId);

    if (achievementsError) {
      console.error('Error deleting student achievements:', achievementsError);
      throw achievementsError;
    }
  } catch (error) {
    console.error('Error in resetStudentPoints:', error);
    throw error;
  }
};

