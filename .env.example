# LTI Tool Provider Configuration
VITE_LTI_INITIATE_LOGIN_URL=https://myprojectplatform.com/api/lti/login
VITE_LTI_TARGET_LINK_URI=https://myprojectplatform.com/lti/lanuch
VITE_LTI_DEEP_LINK_URI=https://myprojectplatform.com/lti/lanuch
