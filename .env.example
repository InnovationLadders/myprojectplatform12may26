VITE_LTI_ACCEPT_TYPES=html,ltiResourceLink,image,file,link,application/pdf
VITE_LTI_ACCEPT_PRESENTATION_TARGETS=iframe,window,embed,frame,popup

# Backend API Configuration (for production)
VITE_BACKEND_API_URL=https://api.yourdomain.com
VITE_CUSTOM_TOKEN_ENDPOINT=/api/auth/generate-custom-token

# Resend Email Service Configuration
# Sign up at https://resend.com to get your API key
VITE_RESEND_API_KEY=your_resend_api_key_here
VITE_FROM_EMAIL=noreply@yourdomain.com
VITE_APP_URL=https://yourapp.com