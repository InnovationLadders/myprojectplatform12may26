VITE_CLASSERA_JWKS_URL=https://partners.classera.com/.well-known/openid-configuration/partners-auto-jwks?id=676
VITE_CLASSERA_ACCESS_TOKEN_URL=https://api-stg.classera.com/LtiProviders/LtiAccessToken?id=676
VITE_CLASSERA_AUTH_URL=https://partners.classera.com/automation_auth
